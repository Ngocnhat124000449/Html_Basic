generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String
  createdAt    DateTime          @default(now())
  progress     UserTagProgress[]
  attempts     Attempt[]
  reviewLogs   ReviewLog[]
  settings     UserSettings?
}

// Tùy biến ôn tập theo từng người (Pha 1). fsrsParams để dành cho Pha 2 (tối ưu
// 21 trọng số FSRS riêng từ ReviewLog) — null = dùng tham số mặc định.
model UserSettings {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyNew        Int      @default(5)
  reviewCap       Int      @default(20)
  targetRetention Float    @default(0.9)
  hiddenTracks    String[] @default([])
  fsrsParams      Json?
  updatedAt       DateTime @updatedAt
}

model Tag {
  id          String            @id @default(cuid())
  // Khóa học: "html" | "css" — dữ liệu cũ mặc định html
  track       String            @default("html")
  name        String
  topic       String
  // Phần lớn của lộ trình (CSS: "Nền tảng", "Giao diện"...) — HTML không dùng
  part        String?
  description String
  order       Int
  questions   Question[]
  progress    UserTagProgress[]
  reviewLogs  ReviewLog[]

  @@unique([track, name])
}

// Nhật ký mỗi lần ôn (P2) — lưu để sau này chạy optimizer FSRS per-khóa.
model ReviewLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  rating        Int // 1 Again, 2 Hard, 3 Good, 4 Easy
  state         Int // state TRƯỚC khi ôn
  stability     Float
  difficulty    Float
  elapsedDays   Int
  scheduledDays Int
  due           DateTime
  reviewedAt    DateTime @default(now())

  @@index([userId, tagId])
  @@index([reviewedAt])
}

enum QuestionType {
  MCQ
  FILL_BLANK
  WRITE_TAG
  FIX_BUG
  WRITE_STRUCTURE
  WRITE_CSS
  WRITE_JS
  WRITE_CMD
  WRITE_JSX
}

model Question {
  id           String       @id @default(cuid())
  tagId        String
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tier         Int
  type         QuestionType
  prompt       String
  options      Json?
  correctIndex Int?
  requirements Json?
  starterCode  String?
  answer       String?
  attempts     Attempt[]
}

model UserTagProgress {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId        String
  tag          Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  ease         Float    @default(2.5)
  intervalDays Int      @default(0)
  dueAt        DateTime @default(now())
  lapses       Int      @default(0)
  mastered     Boolean  @default(false)
  createdAt    DateTime @default(now())

  // FSRS (ts-fsrs Card) — P1. state: 0 New, 1 Learning, 2 Review, 3 Relearning.
  // ease/intervalDays giữ lại để rollback; mastered = stability >= 21.
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  reps           Int       @default(0)
  state          Int       @default(0)
  scheduledDays  Int       @default(0)
  lastReviewedAt DateTime?

  @@unique([userId, tagId])
}

model Attempt {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerText String
  isCorrect  Boolean
  detail     Json?
  createdAt  DateTime @default(now())
}
